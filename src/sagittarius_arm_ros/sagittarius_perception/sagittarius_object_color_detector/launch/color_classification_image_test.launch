<launch>
  <!-- 机械臂 -->
  <arg name="robot_name" default="sgr532"/>
  <include file="$(find sagittarius_moveit)/launch/demo_true.launch" />
  <node pkg="sagittarius_object_color_detector" type="sgr_ctrl.py" name="sgr_ctrl_node" output="screen" ns="$(arg robot_name)"/>

  <!-- 本地测试图片发布 -->
  <arg name="test_image" default="$(find sagittarius_object_color_detector)/test_data/sample_red_block.ppm"/>
  <arg name="image_topic" default="/usb_cam/image_raw"/>
  <arg name="image_rate" default="5.0"/>
  <node pkg="sagittarius_object_color_detector" type="publish_test_image.py" name="publish_test_image_node" output="screen">
    <param name="image_path" value="$(arg test_image)"/>
    <param name="topic" value="$(arg image_topic)"/>
    <param name="rate" value="$(arg image_rate)"/>
    <param name="frame_id" value="usb_cam"/>
  </node>

  <!-- 抓取例程 -->
  <arg name="vision_config" default="$(find sagittarius_object_color_detector)/config/vision_config.yaml"/>
  <arg name="perception_backend" default="grounding_dino"/>
  <arg name="groundingdino_config" default="$(env HOME)/GroundingDINO/groundingdino/config/GroundingDINO_SwinT_OGC.py"/>
  <arg name="groundingdino_weights" default="$(env HOME)/GroundingDINO/weights/groundingdino_swint_ogc.pth"/>
  <arg name="default_target_text" default=""/>
  <arg name="target_topic" default="/grasp_target_text"/>
  <arg name="device" default="cuda"/>
  <arg name="box_threshold" default="0.35"/>
  <arg name="text_threshold" default="0.25"/>
  <arg name="stable_required" default="5"/>
  <arg name="center_tolerance" default="8.0"/>
  <arg name="pick_z" default="0.01"/>
  <arg name="allow_start_without_groundingdino" default="false"/>
  <arg name="allow_start_without_backend" default="$(arg allow_start_without_groundingdino)"/>
  <arg name="drop_after_grasp" default="true"/>
  <arg name="drop_x" default="0.15"/>
  <arg name="drop_y" default="0.24"/>
  <arg name="drop_z" default="0.20"/>

  <node pkg="sagittarius_object_color_detector" type="color_classification.py" name="color_classification_node" output="screen">
    <param name ="vision_config" value = "$(arg vision_config)"/>
    <param name ="arm_name" value = "$(arg robot_name)"/>
    <param name ="image_topic" value = "$(arg image_topic)"/>
    <param name ="perception_backend" value = "$(arg perception_backend)"/>
    <param name ="perception_config" value = "$(arg groundingdino_config)"/>
    <param name ="perception_weights" value = "$(arg groundingdino_weights)"/>
    <param name ="groundingdino_config" value = "$(arg groundingdino_config)"/>
    <param name ="groundingdino_weights" value = "$(arg groundingdino_weights)"/>
    <param name ="default_target_text" value = "$(arg default_target_text)"/>
    <param name ="target_topic" value = "$(arg target_topic)"/>
    <param name ="device" value = "$(arg device)"/>
    <param name ="box_threshold" value = "$(arg box_threshold)"/>
    <param name ="text_threshold" value = "$(arg text_threshold)"/>
    <param name ="stable_required" value = "$(arg stable_required)"/>
    <param name ="center_tolerance" value = "$(arg center_tolerance)"/>
    <param name ="pick_z" value = "$(arg pick_z)"/>
    <param name ="allow_start_without_groundingdino" value = "$(arg allow_start_without_groundingdino)"/>
    <param name ="allow_start_without_backend" value = "$(arg allow_start_without_backend)"/>
    <param name ="drop_after_grasp" value = "$(arg drop_after_grasp)"/>
    <param name ="drop_x" value = "$(arg drop_x)"/>
    <param name ="drop_y" value = "$(arg drop_y)"/>
    <param name ="drop_z" value = "$(arg drop_z)"/>
  </node>
</launch>
