<launch>
  <!-- Robot station: camera + Sagittarius control + lightweight JSON executor. -->
  <arg name="robot_name" default="sgr532"/>
  <arg name="node_name" default="language_guided_executor_node"/>
  <arg name="start_camera" default="true"/>

  <!-- Robot control side stays on the robot station. -->
  <include file="$(find sagittarius_moveit)/launch/demo_true.launch" />
  <node pkg="sagittarius_object_color_detector" type="sgr_ctrl.py" name="sgr_ctrl_node" output="screen" ns="$(arg robot_name)"/>

  <!-- Camera can be disabled if another camera publisher is already running. -->
  <arg name="video_dev" default="/dev/video0"/>
  <arg name="image_width" default="640"/>
  <arg name="image_height" default="480"/>
  <arg name="framerate" default="10"/>
  <arg name="pixel_format" default="mjpeg"/>
  <arg name="io_method" default="mmap"/>
  <arg name="usb_cam_output" default="screen"/>
  <arg name="usb_cam_stderr_log" default="$(env HOME)/.ros/log/usb_cam_stderr.log"/>
  <include if="$(arg start_camera)" file="$(find sagittarius_object_color_detector)/launch/usb_cam.launch">
    <arg name="video_dev" value="$(arg video_dev)"/>
    <arg name="image_width" value="$(arg image_width)"/>
    <arg name="image_height" value="$(arg image_height)"/>
    <arg name="framerate" value="$(arg framerate)"/>
    <arg name="pixel_format" value="$(arg pixel_format)"/>
    <arg name="io_method" value="$(arg io_method)"/>
    <arg name="output" value="$(arg usb_cam_output)"/>
    <arg name="stderr_log" value="$(arg usb_cam_stderr_log)"/>
  </include>

  <!-- Executor consumes AI station observations and reuses vision_config + sgr_ctrl. -->
  <arg name="vision_config" default="$(find sagittarius_object_color_detector)/config/vision_config.yaml"/>
  <arg name="observation_topic" default="/language_guided_grasp/target_observation"/>
  <arg name="execution_feedback_topic" default="/language_guided_grasp/execution_feedback"/>
  <arg name="state_topic" default="/language_guided_executor/state"/>
  <arg name="min_grasp_score" default="0.35"/>
  <arg name="stable_required" default="5"/>
  <arg name="center_tolerance" default="8.0"/>
  <arg name="max_observation_age" default="0.0"/>
  <arg name="pick_z" default="0.01"/>
  <arg name="drop_after_grasp" default="true"/>
  <arg name="drop_x" default="0.15"/>
  <arg name="drop_y" default="0.24"/>
  <arg name="drop_z" default="0.20"/>
  <arg name="ignore_completed_target_until_changed" default="true"/>

  <node pkg="sagittarius_object_color_detector" type="language_guided_executor.py" name="$(arg node_name)" output="screen">
    <param name="vision_config" value="$(arg vision_config)"/>
    <param name="arm_name" value="$(arg robot_name)"/>
    <param name="observation_topic" value="$(arg observation_topic)"/>
    <param name="execution_feedback_topic" value="$(arg execution_feedback_topic)"/>
    <param name="state_topic" value="$(arg state_topic)"/>
    <param name="min_grasp_score" value="$(arg min_grasp_score)"/>
    <param name="stable_required" value="$(arg stable_required)"/>
    <param name="center_tolerance" value="$(arg center_tolerance)"/>
    <param name="max_observation_age" value="$(arg max_observation_age)"/>
    <param name="pick_z" value="$(arg pick_z)"/>
    <param name="drop_after_grasp" value="$(arg drop_after_grasp)"/>
    <param name="drop_x" value="$(arg drop_x)"/>
    <param name="drop_y" value="$(arg drop_y)"/>
    <param name="drop_z" value="$(arg drop_z)"/>
    <param name="ignore_completed_target_until_changed" value="$(arg ignore_completed_target_until_changed)"/>
  </node>
</launch>
